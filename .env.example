# Server Configuration
NODE_ENV=production
PORT=3000

# MongoDB Connection
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/doot?retryWrites=true&w=majority

# Email Configuration (Optional - uses Ethereal test service if not set)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# JWT Secret (for future token-based auth)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Frontend URL (for CORS in production)
FRONTEND_URL=https://your-domain.com

# ==================== TURN SERVER CONFIGURATION ====================
# TURN servers are CRITICAL for production - ~15% of WebRTC connections fail without them
# Options:
# 1. Use free Metered.ca TURN servers (included by default in code)
# 2. Self-host coturn server
# 3. Use paid services like Twilio, Xirsys, etc.

# Custom TURN Server (optional - defaults to Metered.ca if not set)
# VITE_TURN_URL=turn:your-turn-server.com:3478
# VITE_TURN_USERNAME=your-username
# VITE_TURN_CREDENTIAL=your-credential

# For self-hosted coturn:
# VITE_TURN_URL=turn:your-server-ip:3478
# VITE_TURN_USERNAME=webrtc
# VITE_TURN_CREDENTIAL=your-secure-password

{
  "expo": {
    "name": "DOOT",
    "slug": "doot-secure-chat",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0a"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.doot.securechat",
      "infoPlist": {
        "NSCameraUsageDescription": "DOOT needs camera access for video calls",
        "NSMicrophoneUsageDescription": "DOOT needs microphone access for audio and video calls"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a0a"
      },
      "package": "com.doot.securechat",
      "permissions": ["CAMERA", "RECORD_AUDIO", "MODIFY_AUDIO_SETTINGS"]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow DOOT to access your camera for video calls"
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "Allow DOOT to access your microphone for calls"
        }
      ]
    ]
  }
}
